{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "bank-shell": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/bank-shell",
      "sourceRoot": "projects/bank-shell/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "ngx-build-plus:browser",
          "options": {
            "outputPath": "dist/bank-shell",
            "index": "projects/bank-shell/src/index.html",
            "main": "projects/bank-shell/src/main.ts",
            "polyfills": [],
            "tsConfig": "projects/bank-shell/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/bank-shell/public",
                "output": "/"
              }
            ],
            "styles": ["projects/bank-shell/src/styles.css"],
            "extraWebpackConfig": "projects/bank-shell/webpack.config.js",
            "commonChunk": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "extraWebpackConfig": "projects/bank-shell/webpack.prod.config.js"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "ngx-build-plus:dev-server",
          "options": {
            "buildTarget": "bank-shell:build:development",
            "port": 4200,
            "publicHost": "http://localhost:4200",
            "extraWebpackConfig": "projects/bank-shell/webpack.config.js"
          },
          "configurations": {
            "production": {
              "buildTarget": "bank-shell:build:production",
              "extraWebpackConfig": "projects/bank-shell/webpack.prod.config.js"
            },
            "development": {
              "buildTarget": "bank-shell:build:development",
              "extraWebpackConfig": "projects/bank-shell/webpack.config.js"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/bank-shell/tsconfig.spec.json"
          }
        }
      }
    },
    "bank-admin-mfe": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/bank-admin-mfe",
      "sourceRoot": "projects/bank-admin-mfe/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "ngx-build-plus:browser",
          "options": {
            "outputPath": "dist/bank-admin-mfe",
            "index": "projects/bank-admin-mfe/src/index.html",
            "main": "projects/bank-admin-mfe/src/main.ts",
            "polyfills": [],
            "tsConfig": "projects/bank-admin-mfe/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/bank-admin-mfe/public",
                "output": "/"
              }
            ],
            "styles": ["projects/bank-admin-mfe/src/styles.css"],
            "extraWebpackConfig": "projects/bank-admin-mfe/webpack.config.js",
            "commonChunk": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "extraWebpackConfig": "projects/bank-admin-mfe/webpack.prod.config.js"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "ngx-build-plus:dev-server",
          "options": {
            "buildTarget": "bank-admin-mfe:build:development",
            "port": 4201,
            "publicHost": "http://localhost:4201",
            "extraWebpackConfig": "projects/bank-admin-mfe/webpack.config.js"
          },
          "configurations": {
            "production": {
              "buildTarget": "bank-admin-mfe:build:production",
              "extraWebpackConfig": "projects/bank-admin-mfe/webpack.prod.config.js"
            },
            "development": {
              "buildTarget": "bank-admin-mfe:build:development",
              "extraWebpackConfig": "projects/bank-admin-mfe/webpack.config.js"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
